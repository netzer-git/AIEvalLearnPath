# Copy this file to `.env.local` (gitignored) and fill in the values
# you actually want before exposing the app via Cloudflare Tunnel.
# When both vars are unset, auth is disabled and the app is open
# (which is what you want for localhost dev).

# Encryption secret for the iron-session cookie. Must be ≥32 chars.
# Generate one with: node -e "console.log(crypto.randomBytes(32).toString('base64'))"
SESSION_PASSWORD=replace-with-32+-random-chars-from-the-command-above

# The passcode the user types on the /login page. If unset, auth is
# disabled regardless of SESSION_PASSWORD.
APP_PASSCODE=
